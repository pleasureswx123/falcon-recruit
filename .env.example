# =============================================================
# 猎鹰 Falcon AI · docker compose 变量模板
# 复制为 .env 后按需调整；.env 不会入库（已在 .gitignore）。
# =============================================================

# ---- PostgreSQL ----
POSTGRES_USER=falcon
POSTGRES_PASSWORD=falcon_dev_pw
POSTGRES_DB=falcon
# 宿主机映射端口（仅绑定在 127.0.0.1，本地开发需要直连 DB 时使用）
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- 生产 override (docker-compose.prod.yml) 使用 ----
# 后端容器对外暴露端口
BACKEND_PORT=8000
# 前端容器对外暴露端口
FRONTEND_PORT=3000
# 前端构建时会把这个地址烧录进 bundle
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# 后端 CORS 允许来源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 上传 ZIP 大小上限（MB）
MAX_UPLOAD_MB=200

# ---- LLM 配置（注入到 backend 容器） ----
# 空则自动降级为规则式逻辑
OPENAI_API_KEY=
# 火山方舟 / DeepSeek / OpenAI 等 /v1 兼容端点
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-1-5-pro-32k-250115
