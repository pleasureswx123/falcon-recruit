# =============================================================
# 猎鹰 Falcon AI · docker compose 变量模板
# 复制为 .env 后按需调整；.env 不会入库（已在 .gitignore）。
# =============================================================

# ---- PostgreSQL ----
# 生产部署必填（docker-compose.prod.yml 强制校验；弱密码会直接拒绝启动）
POSTGRES_USER=falcon
POSTGRES_PASSWORD=falcon_dev_pw   # ← 生产必须改成强随机串
POSTGRES_DB=falcon
# 宿主机映射端口（避免与现有服务冲突，如 5432 被占用可改为 5433）
POSTGRES_PORT=5433

# ---- Redis ----
# 避免与现有 Redis 服务冲突，如 6379 被占用可改为 6380
REDIS_PORT=6380
# Redis 连接 URL（用于后端 Session 存储和缓存）
# 开发环境：通过 docker compose 启动后，后端连接宿主机的 Redis
# 生产环境：docker-compose.prod.yml 会覆盖为容器内网络地址
REDIS_URL=redis://127.0.0.1:6379/0

# ---- 生产 override (docker-compose.prod.yml) 使用 ----
# Nginx 容器对外暴露端口（统一入口,前后端均通过 Nginx 代理）
# 注意: 如果服务器 80 端口已被占用,请修改为其他端口(如 8080)
NGINX_PORT=8080

# 上传 ZIP 大小上限（MB）
MAX_UPLOAD_MB=200

# ---- LLM 配置（注入到 backend 容器） ----
# 空则自动降级为规则式逻辑
OPENAI_API_KEY=
# 火山方舟 / DeepSeek / OpenAI 等 /v1 兼容端点
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-1-5-pro-32k-250115
