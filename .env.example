# =============================================================
# 猎鹰 Falcon AI · docker compose 变量模板
# 复制为 .env 后按需调整；.env 不会入库（已在 .gitignore）。
# =============================================================

# ---- PostgreSQL ----
# 生产部署必填（docker-compose.prod.yml 强制校验；弱密码会直接拒绝启动）
POSTGRES_USER=falcon
POSTGRES_PASSWORD=falcon_dev_pw   # ← 生产必须改成强随机串
POSTGRES_DB=falcon
# 宿主机映射端口（仅绑定在 127.0.0.1，本地开发需要直连 DB 时使用）
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- 生产 override (docker-compose.prod.yml) 使用 ----
# Nginx 容器对外暴露端口（统一入口）
NGINX_PORT=80
# 后端容器对外暴露端口（生产环境通过 Nginx 代理，不再直接暴露）
# BACKEND_PORT=8000
# 前端容器对外暴露端口（生产环境通过 Nginx 代理，不再直接暴露）
# FRONTEND_PORT=3000
# 前端构建时会把这个地址烧录进 bundle
# 生产环境使用相对路径 /api，通过 Nginx 代理到后端
NEXT_PUBLIC_API_BASE_URL=/api

# 后端 CORS 允许来源（多个用逗号分隔）
# 生产环境通过 Nginx 统一入口，可设置为 * 或具体域名
CORS_ORIGINS=*

# 上传 ZIP 大小上限（MB）
MAX_UPLOAD_MB=200

# ---- LLM 配置（注入到 backend 容器） ----
# 空则自动降级为规则式逻辑
OPENAI_API_KEY=
# 火山方舟 / DeepSeek / OpenAI 等 /v1 兼容端点
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-1-5-pro-32k-250115

# ---- 生产加固（docker-compose.prod.yml 强制）----
# HR 前端与 API 之间的共享密钥（X-API-Key 请求头），生产必填
FALCON_API_KEY=
# per-IP 限流（slowapi 语法）
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_EXPORT=30/minute
# ZIP 炸弹防御
ZIP_EXPAND_RATIO_MAX=10
ZIP_MAX_FILES=5000
