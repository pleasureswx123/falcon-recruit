# 应用基础配置
APP_NAME=Falcon AI
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

# 服务监听
HOST=127.0.0.1
PORT=8000

# 数据库（开发环境：连接宿主机 PostgreSQL 容器）
# 生产环境通过 docker-compose.prod.yml 注入，使用服务名 "postgres" 而非 127.0.0.1
DATABASE_URL=postgresql+asyncpg://falcon:falcon_dev_pw@127.0.0.1:5432/falcon
DATABASE_ECHO=false

# Redis（Session 存储 + 缓存）
# 开发环境：连接宿主机 Redis 容器（需先运行 docker compose up -d）
# 生产环境：通过 docker-compose.prod.yml 注入，使用服务名 "redis"
REDIS_URL=redis://127.0.0.1:6379/0

# 文件存储根目录（Phase 3：ZIP 解压与重命名产物）
STORAGE_ROOT=./storage
# 上传 ZIP 包大小上限（MB）
MAX_UPLOAD_MB=200

# LLM（Phase 4 启用，留空则自动降级到规则式）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# LLM_MODEL=gpt-4o
