# 应用基础配置
APP_NAME=Falcon AI
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

# 服务监听
HOST=127.0.0.1
PORT=8000

# 数据库（开发 / 生产统一使用 PostgreSQL + asyncpg，搭配仓库根目录 docker-compose.yml 起的容器）
DATABASE_URL=postgresql+asyncpg://falcon:falcon_dev_pw@127.0.0.1:5432/falcon
DATABASE_ECHO=false

# Redis（搭配仓库根目录 docker-compose.yml 起的 Redis；目前预留接口）
REDIS_URL=redis://127.0.0.1:6379/0

# 文件存储根目录（Phase 3：ZIP 解压与重命名产物）
STORAGE_ROOT=./storage
# 上传 ZIP 包大小上限（MB）
MAX_UPLOAD_MB=200

# LLM（Phase 4 启用）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# LLM_MODEL=gpt-4o

# ---- 生产加固（留空则为开发/开放模式）----
# API Key：留空时 /api/* 不鉴权（仅限本地 smoke）。生产必须设置一个强随机串。
# FALCON_API_KEY=
# per-IP 限流策略（slowapi 语法：N/minute、N/second）
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_EXPORT=30/minute
# ZIP 炸弹防御：解压后总大小上限 = MAX_UPLOAD_MB * ZIP_EXPAND_RATIO_MAX
ZIP_EXPAND_RATIO_MAX=10
ZIP_MAX_FILES=5000
